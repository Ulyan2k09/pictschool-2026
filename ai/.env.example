# Copy this file to .env and set secrets locally.

# LLM provider settings
OPENAI_API_KEY=
OPENAI_BASE_URL=https://foundation-models.api.cloud.ru/v1
AGENT_LLM_MODEL=gpt-4o-mini

# Agent runtime settings
AGENT_BACKEND_URL=http://127.0.0.1:8080
AGENT_LLM_ENABLED=true
AGENT_ACTOR_ID=agent
AGENT_POLL_INTERVAL_SEC=0.8
AGENT_REQUEST_TIMEOUT_SEC=8.0
